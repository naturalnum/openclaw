# Gateway auth
OPENCLAW_GATEWAY_TOKEN=change-me-gateway-token

# Model provider keys
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

# Claude shell command inside the container.
# OPENCLAW_CLAUDE_API_KEY=
# OPENCLAW_CLAUDE_BASE_URL=https://api.deepseek.com/anthropic
# OPENCLAW_CLAUDE_MODEL=deepseek-chat
# OPENCLAW_CLAUDE_SMALL_FAST_MODEL=deepseek-chat
# OPENCLAW_CLAUDE_DISABLE_NONESSENTIAL_TRAFFIC=true

# Skill registry / ClawHub
CLAWHUB_REGISTRY=http://127.0.0.1:3000
CLAWHUB_SITE=http://127.0.0.1:3000
CLAWHUB_WORKDIR=/home/node/.openclaw

# Optional
# OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
