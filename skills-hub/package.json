{
  "name": "skills-hub",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "cd client && npx vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npx vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "node --experimental-strip-types server/src/index.ts",
    "typecheck": "tsc --noEmit -p server/tsconfig.json && vue-tsc --noEmit -p client/tsconfig.json"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.0",
    "drizzle-orm": "^0.38.0",
    "pg": "^8.11.0",
    "zod": "^3.24.0",
    "bcryptjs": "^2.4.3",
    "busboy": "^1.6.0",
    "tar": "^7.0.0",
    "unzipper": "^0.12.0",
    "yaml": "^2.4.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "pinia": "^2.3.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^22.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/busboy": "^1.5.0",
    "@types/pg": "^8.11.0",
    "@types/tar": "^6.1.0",
    "@types/unzipper": "^0.10.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.0.0",
    "concurrently": "^9.0.0"
  }
}
